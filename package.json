{
  "name": "yieldpilot",
  "version": "0.1.0",
  "private": true,
  "description": "Production-oriented autonomous onchain agent with gas-aware execution, protocol adapters, and yield optimization as the first live strategy.",
  "homepage": "https://github.com/SebastianBoehler/yieldpilot#readme",
  "bugs": {
    "url": "https://github.com/SebastianBoehler/yieldpilot/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SebastianBoehler/yieldpilot.git"
  },
  "keywords": [
    "defi",
    "cross-chain",
    "yield-optimization",
    "autonomous-agents",
    "google-adk",
    "lifi",
    "aave",
    "stablecoins",
    "nextjs",
    "typescript"
  ],
  "packageManager": "bun@1.3.5",
  "engines": {
    "node": ">=22",
    "bun": ">=1.3.5"
  },
  "scripts": {
    "postinstall": "DATABASE_URL=${DATABASE_URL:-postgresql://postgres:postgres@127.0.0.1:5432/yieldpilot?schema=public} prisma generate",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:web": "next start",
    "start:worker": "tsx scripts/agent-worker.ts",
    "lint": "eslint . --ignore-pattern coverage --ignore-pattern .next",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "db:generate": "DATABASE_URL=${DATABASE_URL:-postgresql://postgres:postgres@127.0.0.1:5432/yieldpilot?schema=public} prisma generate",
    "db:push": "DATABASE_URL=${DATABASE_URL:-postgresql://postgres:postgres@127.0.0.1:5432/yieldpilot?schema=public} node scripts/db-push.mjs",
    "worker": "bun run start:worker"
  },
  "dependencies": {
    "@aave-dao/aave-address-book": "^4.47.4",
    "@aave/core-v3": "^1.19.3",
    "@aave/periphery-v3": "^2.5.2",
    "@google/adk": "^0.5.0",
    "@lifi/sdk": "^3.16.0",
    "@prisma/client": "^6.19.2",
    "@tanstack/react-query": "^5.90.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "node-cron": "^4.2.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "viem": "^2.47.1",
    "wagmi": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^6.19.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
